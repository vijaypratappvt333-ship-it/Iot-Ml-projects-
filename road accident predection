5. Python Code for Road Accident Prediction
# Step 1: Import Libraries
import pandas as pd
import numpy as np
from sklearn.model_selection import train_test_split
from sklearn.preprocessing import LabelEncoder
from sklearn.tree import DecisionTreeClassifier
from sklearn.metrics import accuracy_score

# Step 2: Load Dataset
data = pd.read_csv("accident_data.csv")

print(data.head())

# Step 3: Data Preprocessing
le = LabelEncoder()

data['Weather'] = le.fit_transform(data['Weather'])
data['Road_Type'] = le.fit_transform(data['Road_Type'])
data['Traffic'] = le.fit_transform(data['Traffic'])
data['Visibility'] = le.fit_transform(data['Visibility'])

# Step 4: Define Features and Target
X = data.drop('Accident', axis=1)
y = data['Accident']

# Step 5: Train Test Split
X_train, X_test, y_train, y_test = train_test_split(X, y, test_size=0.2)

# Step 6: Train Model
model = DecisionTreeClassifier()

model.fit(X_train, y_train)

# Step 7: Prediction
y_pred = model.predict(X_test)

# Step 8: Accuracy
accuracy = accuracy_score(y_test, y_pred)

print("Model Accuracy:", accuracy)
6. Example Prediction
# Example new data
new_data = [[1,0,2,70,1]]

prediction = model.predict(new_data)

if prediction == 1:
    print("High Risk of Accident")
else:
    print("Low Risk of Accident")
